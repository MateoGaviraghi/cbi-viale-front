# =========================================================================
# CBI Viale — FRONT · plantilla de env vars (commitear SIN valores reales)
# =========================================================================
# Copiar a .env y completar con valores locales.
# Los secretos (DB, JWT, Resend) viven SOLO en el back (cbi_viale_back).

# URL pública del sitio (usada en og:url, sitemap, canonical).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# URL base del back. En prod apuntar al dominio del API.
# - Dev: http://localhost:3001
# - Prod: https://api.cbiviale.com.ar  (o la URL de Railway temporal)
API_URL="http://localhost:3001"
